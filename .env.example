# 🍎 Apple Store - Environment Variables Template
# Copy file này thành .env và điền thông tin của bạn

# 1. Cấu hình MongoDB Express (Giao diện quản lý Database)
# Tài khoản đăng nhập vào http://localhost:8081
MONGO_EXPRESS_USER=admin
MONGO_EXPRESS_PASSWORD=change_me_in_production

# 2. Cấu hình Backend Security
# JWT_SECRET: Dùng để mã hóa token. Hãy đổi thành một chuỗi ngẫu nhiên dài khi chạy thật.
JWT_SECRET=apple_store_secret_key_change_in_production

# 3. Các cấu hình khác (Tùy chọn)
# PORT=5001
# NODE_ENV=development
